    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"{{ $('⚙️ Config (EDIT THIS)').first().json.AI_MODEL }}\",\n  \"response_format\": { \"type\": \"json_object\" },\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an expert Facebook Ads strategist specializing in Indian education and visa consultancy marketing. Your target audience is Indian students aged 18-30 who want to study abroad.\\n\\nGiven a campaign brief from a visa consultancy, generate a complete ad campaign setup as a JSON object.\\n\\nCRITICAL RULES:\\n- NEVER target age above 30\\n- ALWAYS include study abroad and test prep interests\\n- Budget values must be in PAISE (multiply INR by 100)\\n- Ad copy must NEVER guarantee visa approval\\n- Use language like 'expert guidance', 'personalized consultation', 'trusted advisors'\\n- Generate 2 ad copy variants for A/B testing\\n- Include relevant hashtags for organic reach\\n- The ad must feel human, emotional, and aspirational\\n\\nReturn ONLY a valid JSON object in this exact format:\\n{\\n  \\\"campaign_name\\\": \\\"descriptive name based on brief\\\",\\n  \\\"ad_set_name\\\": \\\"descriptive ad set name\\\",\\n  \\\"targeting\\\": {\\n    \\\"age_min\\\": 18,\\n    \\\"age_max\\\": 30,\\n    \\\"geo_locations\\\": {\\n      \\\"countries\\\": [\\\"IN\\\"],\\n      \\\"cities\\\": [{\\\"key\\\": \\\"2771943\\\", \\\"name\\\": \\\"Delhi\\\"}, {\\\"key\\\": \\\"2772935\\\", \\\"name\\\": \\\"Mumbai\\\"}, {\\\"key\\\": \\\"2771157\\\", \\\"name\\\": \\\"Ahmedabad\\\"}, {\\\"key\\\": \\\"2774009\\\", \\\"name\\\": \\\"Pune\\\"}, {\\\"key\\\": \\\"2772940\\\", \\\"name\\\": \\\"Bangalore\\\"}]\\n    },\\n    \\\"flexible_spec\\\": [{\\n      \\\"interests\\\": [\\n        {\\\"id\\\": \\\"6003012175633\\\", \\\"name\\\": \\\"Study abroad\\\"},\\n        {\\\"id\\\": \\\"6003395407822\\\", \\\"name\\\": \\\"IELTS\\\"},\\n        {\\\"id\\\": \\\"6003205898084\\\", \\\"name\\\": \\\"Higher education\\\"},\\n        {\\\"id\\\": \\\"6003139266461\\\", \\\"name\\\": \\\"TOEFL\\\"},\\n        {\\\"id\\\": \\\"6003384248805\\\", \\\"name\\\": \\\"Master's degree\\\"}\\n      ]\\n    }],\\n    \\\"publisher_platforms\\\": [\\\"facebook\\\", \\\"instagram\\\"],\\n    \\\"facebook_positions\\\": [\\\"feed\\\", \\\"story\\\", \\\"reel\\\"],\\n    \\\"instagram_positions\\\": [\\\"stream\\\", \\\"story\\\", \\\"reels\\\", \\\"explore\\\"]\\n  },\\n  \\\"ad_copies\\\": [\\n    {\\n      \\\"headline\\\": \\\"max 40 chars - punchy headline\\\",\\n      \\\"primary_text\\\": \\\"125-300 chars - compelling ad body with emoji\\\",\\n      \\\"description\\\": \\\"max 30 chars\\\",\\n      \\\"call_to_action\\\": \\\"LEARN_MORE\\\",\\n      \\\"hashtags\\\": \\\"#relevant #hashtags\\\"\\n    },\\n    {\\n      \\\"headline\\\": \\\"variant 2\\\",\\n      \\\"primary_text\\\": \\\"variant 2 body\\\",\\n      \\\"description\\\": \\\"variant 2 desc\\\",\\n      \\\"call_to_action\\\": \\\"SIGN_UP\\\",\\n      \\\"hashtags\\\": \\\"#relevant #hashtags\\\"\\n    }\\n  ],\\n  \\\"rationale\\\": \\\"Brief explanation of strategy\\\"\\n}\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Campaign brief: {{ $json.brief }}\\nDaily budget: {{ $json.daily_budget_inr }} INR\\nPlatform: {{ $json.platform }}\"\n    }\n  ]\n}",
        "options": {
          "timeout": 60000
        }
      },
      "id": "2f009bcf-0dbe-4a2b-a30f-bf1a8e171348",
      "name": "AI Generate Campaign",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
