    {
      "parameters": {
        "jsCode": "// Parse AI response\nconst aiResponse = $input.first().json;\nconst aiContent = aiResponse.choices[0].message.content;\nconst campaign = JSON.parse(aiContent);\n\n// Get config\nconst config = $('⚙️ Config (EDIT THIS)').first().json;\n\n// Get original sheet data\nconst sheetData = $('Filter Pending Rows').first().json;\n\n// Calculate budget in paise\nconst dailyBudgetPaise = (parseInt(sheetData.daily_budget_inr) * 100).toString();\n\n// Determine if using existing campaign\nconst existingCampaignId = sheetData.campaign_id && sheetData.campaign_id.toString().trim() !== '' \n  ? sheetData.campaign_id.toString().trim() \n  : null;\n\n// Pick first ad copy variant\nconst adCopy = campaign.ad_copies[0];\n\n// Build targeting WITHOUT interests (use broad targeting)\n// Meta Advantage+ will optimize delivery based on age + location\nconst safeTargeting = {\n  age_min: 18,\n  age_max: 30,\n  geo_locations: {\n    countries: [\"IN\"],\n    cities: [\n      {\"key\": \"2771943\", \"name\": \"Delhi\"},\n      {\"key\": \"2772935\", \"name\": \"Mumbai\"},\n      {\"key\": \"2771157\", \"name\": \"Ahmedabad\"},\n      {\"key\": \"2774009\", \"name\": \"Pune\"},\n      {\"key\": \"2772940\", \"name\": \"Bangalore\"}\n    ]\n  },\n  publisher_platforms: [\"facebook\", \"instagram\"],\n  instagram_positions: [\"stream\", \"story\", \"reels\", \"explore\"],\n  targeting_automation: {\n    advantage_audience: 0\n  }\n};\n\nreturn [{\n  json: {\n    // Config values\n    ad_account_id: config.META_AD_ACCOUNT_ID,\n    access_token: config.META_ACCESS_TOKEN,\n    page_id: config.META_PAGE_ID,\n    landing_url: config.LANDING_PAGE_URL,\n    \n    // Original sheet data\n    row_id: sheetData.row_id,\n    image_url: sheetData.image_url,\n    platform: sheetData.platform,\n    \n    // Campaign config\n    campaign_name: campaign.campaign_name,\n    ad_set_name: campaign.ad_set_name,\n    daily_budget_paise: dailyBudgetPaise,\n    existing_campaign_id: existingCampaignId,\n    \n    // Use safe targeting (no invalid interest IDs)\n    targeting: JSON.stringify(safeTargeting),\n    \n    // Ad creative content\n    headline: adCopy.headline,\n    primary_text: adCopy.primary_text + '\\n\\n' + adCopy.hashtags,\n    description: adCopy.description,\n    call_to_action: adCopy.call_to_action,\n    \n    // Full AI output for logging\n    ai_full_output: aiContent,\n    rationale: campaign.rationale,\n    all_copies: JSON.stringify(campaign.ad_copies)\n  }\n}];"
      },
