    },
    {
      "parameters": {
        "url": "=https://sheets.googleapis.com/v4/spreadsheets/{{ $('⚙️ Config').first().json.SPREADSHEET_ID }}/values/{{ encodeURIComponent(\"'\" + ('Leads - ' + ($('Filter: Has Form ID').first().json.brief || 'Unknown').toString().replace(/[^a-zA-Z0-9 ]/g, '').substring(0, 40).trim()) + \"'\") }}!A:A",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googleSheetsOAuth2Api",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
