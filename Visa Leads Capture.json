      "typeVersion": 4.4,
      "position": [
        1088,
        0
      ],
      "id": "9b037d5e-0ef7-401c-9c7f-d74b1cb9556c",
      "name": "Read Existing Leads",
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "Dq8gwWNvo1Lo2KtO",
          "name": "Google Sheets account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const config = $('⚙️ Config').first().json;\nconst campaignRow = $('Filter: Has Form ID').first().json;\nconst existingLeadsResponse = $('Read Existing Leads').first().json;\n\n// Explicitly reference Fetch Leads from Meta, NOT $input\nconst metaResponse = $('Fetch Leads from Meta').first().json;\nconst leads = metaResponse.data || [];\n\nif (leads.length === 0) return [];\n\n// Build set of existing lead IDs from sheet column A\nconst existingIds = new Set();\nconst existingValues = existingLeadsResponse.values || [];\nfor (const row of existingValues) {\n  if (row[0] && row[0] !== 'lead_id') {\n    existingIds.add(row[0]);\n  }\n}\n\nconst briefText = (campaignRow.brief || 'Unknown').toString();\nconst sheetTabName = 'Leads - ' + briefText.replace(/[^a-zA-Z0-9 ]/g, '').substring(0, 40).trim();\n\nconst parsedLeads = [];\nfor (const lead of leads) {\n  if (existingIds.has(lead.id)) continue;\n\n  const fieldData = lead.field_data || [];\n  const getField = (key) => {\n    const field = fieldData.find(f => f.name === key);\n    return field ? field.values[0] : '';\n  };\n\n  parsedLeads.push({\n    lead_id: lead.id,\n    full_name: getField('full_name'),\n    email: getField('email'),\n    phone: getField('phone_number'),\n    preferred_country: getField('preferred_country'),\n    campaign_brief: briefText.substring(0, 80),\n    ad_name: lead.ad_name || '',\n    form_id: campaignRow.created_form_id,\n    submitted_at: lead.created_time,\n    status: 'new',\n    sheet_tab_name: sheetTabName,\n    spreadsheet_id: config.SPREADSHEET_ID\n  });\n}\n\nif (parsedLeads.length === 0) return [];\n\nreturn parsedLeads.map(lead => ({ json: lead }));"
      },
      "id": "0a10bf9b-9886-4b90-8fda-9c9887bfa5a9",
      "name": "Parse Leads",
